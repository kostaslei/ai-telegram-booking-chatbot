      "parameters": {
        "jsCode": "// Get state from previous HTTP node\nconst state = items[0].json;\n\n// Get data from Set node\nconst user_id = $('Extract').first().json.user_id;\nconst message = $('Extract').first().json.message;\n\n// If no state → initialize\nif (!state || Object.keys(state).length === 0) {\n  return [{\n    json: {\n      user_id,\n      message,\n      state: {\n        intent: null,\n        date: null,\n        time: null,\n        next_action: null,\n        reply: null,\n        current_date: Date().toString()\n      }\n    }\n  }];\n}\nstate.current_date = new Date().toISOString();\n// Otherwise keep existing state\nreturn [{\n  json: {\n    user_id,\n    message,\n    state\n  }\n}];"
      },
