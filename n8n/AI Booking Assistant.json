    {
      "parameters": {
        "jsCode": "let booking = null;\nlet cancel = null;\nlet text = \"\";\n\ntry {\n  booking = $('POST-Book').first().json.success;\n} catch (e) {\n  booking = null;\n}\n\ntry {\n  cancel = $('POST-Cancel').first().json.success;\n} catch (e) {\n  cancel = null;\n}\n\nif (booking === true) {\n  text = \"Your booking has been confirmed!\";\n} else if (cancel === true) {\n  text = \"Your booking has been canceled!\";\n} else {\n  text = \"Something went wrong. Please try again.\";\n}\n\n\nreturn [{ json: { reply: text } }];"
      },
