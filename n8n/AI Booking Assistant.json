    {
      "parameters": {
        "jsCode": "const slots = $input.first().json.slots;\n\nlet text = $('LLM').first().json.reply + \"\\n\\n\";\n\nfor (const d of slots) {\n  text += `📅 ${d}\\n\\n`;\n}\n\ntext += \"Which one works?\\n\"\n\nreturn [{ json: { reply: text } }];"
      },
